<sukiUi:SukiWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ArkPlot.Avalonia.ViewModels"
    xmlns:controls="using:ArkPlot.Avalonia.Views.Controls"
    xmlns:models="using:ArkPlot.Avalonia.Models"
    xmlns:sukiUi="using:SukiUI.Controls"
    xmlns:c="using:CalcBinding"
    mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
    x:Class="ArkPlot.Avalonia.Views.TtsWindow"
    x:DataType="vm:TtsViewModel"
    Title="TTS 语音生成"
    Width="1200" Height="800"
    MinWidth="900" MinHeight="600">

  <Window.Styles>
    <Style Selector="Border.PlayingRow">
      <Style.Animations>
        <Animation Duration="0:0:1.2" IterationCount="Infinite" PlaybackDirection="Alternate">
          <KeyFrame Cue="0%">
            <Setter Property="Background" Value="#0040C8FF"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Background" Value="#3040C8FF"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="400,*">
    <!-- ======================== 左面板 ======================== -->
    <Border Grid.Column="0" BorderBrush="#30FFFFFF" BorderThickness="0,0,1,0">
      <ScrollViewer>
        <DockPanel Margin="12,8">

        <!-- ffmpeg 通知条 -->
        <Border DockPanel.Dock="Top" IsVisible="{Binding ShowFfmpegNotice}"
                Background="#2080C0FF" BorderBrush="#4080C0FF"
                BorderThickness="1" CornerRadius="6"
                Margin="0,0,0,10" Padding="10,8">
          <DockPanel>
            <Button DockPanel.Dock="Right" Content="✕"
                    Command="{Binding DismissFfmpegNoticeCommand}"
                    Background="Transparent" BorderThickness="0"
                    Padding="6,2" FontSize="11"
                    IsEnabled="{c:Binding !IsDownloadingFfmpeg}"
                    VerticalAlignment="Center" Margin="8,0,0,0"/>
            <Button DockPanel.Dock="Right" Content="下载"
                    Command="{Binding DownloadFfmpegCommand}"
                    IsEnabled="{c:Binding !IsDownloadingFfmpeg}"
                    Classes="Rounded Accent"
                    VerticalAlignment="Center" Margin="8,0,0,0"
                    Padding="12,4" FontSize="12"/>
            <TextBlock Text="{Binding FfmpegNoticeText}"
                       VerticalAlignment="Center" FontSize="12"
                       TextWrapping="Wrap"/>
          </DockPanel>
        </Border>

        <!-- 角色立绘 -->
        <controls:PortraitPanel DockPanel.Dock="Top" Margin="0,0,0,10"
                             DataContext="{Binding PortraitPanel}"/>

        <!-- 小说文件选择 -->
        <TextBlock DockPanel.Dock="Top" Text="小说文件" FontSize="12"
                   Opacity="0.6" Margin="0,0,0,4"/>
        <Border DockPanel.Dock="Top" BorderBrush="#30FFFFFF"
                BorderThickness="1" CornerRadius="4" Margin="0,0,0,8"
                MaxHeight="80">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding NovelFiles}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <RadioButton Content="{Binding FileName}"
                               IsChecked="{Binding IsSelected}"
                               GroupName="NovelFile"
                               Margin="4,2"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!-- 音色配置 -->
        <Button DockPanel.Dock="Top" Content="🎙 音色配置 🔻" Margin="0,0,0,8"
                HorizontalAlignment="Stretch" Classes="Rounded">
          <Button.Flyout>
            <Flyout Placement="RightEdgeAlignedTop">
              <Flyout.FlyoutPresenterTheme>
                <ControlTheme TargetType="FlyoutPresenter">
                  <Setter Property="Background"
                      Value="{DynamicResource SukiInformationForeground}" />
                  <Setter Property="CornerRadius" Value="8" />
                  <Setter Property="BorderBrush" Value="Gray" />
                  <Setter Property="BorderThickness" Value="1" />
                  <Setter Property="Padding" Value="12" />
                </ControlTheme>
              </Flyout.FlyoutPresenterTheme>
              <controls:VoiceConfigPanel DataContext="{Binding $parent[Window].((vm:TtsViewModel)DataContext).VoiceConfigPanel}"
                                         Width="500" Height="400"/>
            </Flyout>
          </Button.Flyout>
        </Button>

        <!-- 输出目录 -->
        <TextBlock DockPanel.Dock="Top" Text="输出目录" FontSize="12"
                   Opacity="0.6" Margin="0,0,0,4"/>
        <TextBox DockPanel.Dock="Top" Text="{Binding TtsOutputDir}"
                 Margin="0,0,0,8"/>

        <!-- 进度 -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
          <TextBlock Text="{Binding ProgressText}" FontSize="12" Margin="0,0,0,4"/>
          <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="6"
                       CornerRadius="3"/>
          <TextBlock Text="{Binding TotalProgressText}" FontSize="11"
                     Opacity="0.5" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,8">
          <Button Content="生成整章" Command="{Binding StartGenerateCommand}"
                  IsEnabled="{c:Binding !IsGenerating}"
                  Width="120" Classes="Rounded Accent"/>
          <Button Content="取消" Command="{Binding CancelCommand}"
                  IsEnabled="{Binding IsGenerating}"
                  Width="120" Classes="Rounded"/>
        </StackPanel>

        <!-- 日志 -->
        <Border DockPanel.Dock="Top" BorderBrush="#20FFFFFF"
                BorderThickness="1" CornerRadius="4">
          <ScrollViewer MaxHeight="200">
            <TextBox Text="{Binding LogText}" IsReadOnly="True"
                     TextWrapping="Wrap" Background="Transparent"
                     FontSize="11" AcceptsReturn="False"/>
          </ScrollViewer>
        </Border>
        </DockPanel>
      </ScrollViewer>
    </Border>

    <!-- ======================== 右面板 ======================== -->
    <DockPanel Grid.Column="1" Margin="12,8">

      <!-- 顶部: 章节选择 + 搜索 -->
      <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto"
            Margin="0,0,0,8">
        <ComboBox Grid.Column="0"
                  ItemsSource="{Binding Chapters}"
                  SelectedItem="{Binding SelectedChapter}"
                  PlaceholderText="选择章节...">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding DisplayText}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Grid.Column="1" Content="◄"
                Command="{Binding PrevChapterCommand}" Margin="4,0"/>
        <Button Grid.Column="2" Content="►"
                Command="{Binding NextChapterCommand}"/>
      </Grid>

      <TextBox DockPanel.Dock="Top" Text="{Binding SearchText}"
               Watermark="搜索片段或角色名..." Margin="0,0,0,8"/>

      <!-- 连播控制 -->
      <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                  HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,8">
        <Button Content="{Binding PlayButtonText}"
                Command="{Binding PlayFromSelectedCommand}"
                HorizontalAlignment="Center"
                Height="36" MinWidth="180" FontSize="14"
                Classes="Rounded Accent"/>
        <Button Content="⏮ 上一句"
                Command="{Binding PlayPrevCommand}"
                IsEnabled="{Binding IsPlaying}"
                Height="36" Width="100" FontSize="13"
                Classes="Rounded"/>
        <Button Content="下一句 ⏭"
                Command="{Binding PlayNextCommand}"
                IsEnabled="{Binding IsPlaying}"
                Height="36" Width="100" FontSize="13"
                Classes="Rounded"/>
        <Button Content="■ 停止"
                Command="{Binding StopPlayCommand}"
                IsEnabled="{Binding IsPlaying}"
                Height="36" Width="80" FontSize="14"
                Classes="Rounded"/>
      </StackPanel>

      <!-- 片段表格 + Gallery + 导出按钮 -->
      <Grid RowDefinitions="*,Auto,Auto">
        <!-- 片段表格 -->
        <DataGrid Grid.Row="0"
                  x:Name="SegmentsDataGrid"
                  ItemsSource="{Binding FilteredSegments}"
                  SelectedItem="{Binding SelectedSegment}"
                  SelectionMode="Extended"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  GridLinesVisibility="Horizontal"
                  RowHeight="40"
                  Margin="0,0,0,8">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="生成选中行"
                        Command="{Binding $parent[DataGrid].((vm:TtsViewModel)DataContext).GenerateSelectedSegmentsCommand}"
                        IsEnabled="{c:Binding !$parent[DataGrid].((vm:TtsViewModel)DataContext).IsGenerating}"/>
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="#" Width="40">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:SegmentRow">
                  <Grid>
                    <!-- 普通行 -->
                    <Border Classes="PlayingRow" CornerRadius="2"
                            IsVisible="{Binding !IsScenePlaceholder}">
                      <TextBlock Text="{Binding Index}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 FontSize="11"/>
                    </Border>
                    <!-- 场景占位行：跨列场景卡片 -->
                    <controls:ScenePlaceholderCard IsVisible="{Binding IsScenePlaceholder}"/>
                  </Grid>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="角色" Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:SegmentRow">
                  <TextBlock Text="{Binding CharacterName}"
                             IsVisible="{Binding !IsScenePlaceholder}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="类型" Width="50">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:SegmentRow">
                  <TextBlock Text="{Binding SegmentType}"
                             IsVisible="{Binding !IsScenePlaceholder}"
                             Opacity="0.6"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="台词" Width="*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:SegmentRow">
                  <TextBlock Text="{Binding NovelText}"
                             IsVisible="{Binding !IsScenePlaceholder}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center"
                             Margin="4,0">
                    <ToolTip.Tip>
                      <TextBlock Text="{Binding NovelText}"
                                 TextWrapping="Wrap"
                                 MaxWidth="400"/>
                    </ToolTip.Tip>
                  </TextBlock>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="音频" Width="300">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:SegmentRow">
                  <!-- 普通行：音频控件 -->
                  <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center" Margin="2,1,6,1"
                        IsVisible="{Binding !IsScenePlaceholder}">
                    <Border Grid.Column="0" IsVisible="{Binding HasAudio}">
                      <controls:AudioPlayerControl DataContext="{Binding AudioPlayer}"
                                                MinWidth="200"/>
                    </Border>
                    <TextBlock Grid.Column="1" IsVisible="{c:Binding !HasAudio}"
                               Text="{Binding AudioStatus}"
                               VerticalAlignment="Center"
                               Opacity="{Binding AudioOpacity}"
                               Margin="4,0"/>
                  </Grid>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>

        <!-- 场景 Gallery -->
        <controls:GalleryPanel Grid.Row="1" DataContext="{Binding GalleryPanel}"/>

        <!-- 导出按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="8" Margin="0,8,0,0">
          <Button Content="导出当前章节 MP3"
                  Command="{Binding ExportCurrentChapterCommand}"/>
          <Button Content="导出全部章节 MP3"
                  Command="{Binding ExportAllChaptersCommand}"/>
        </StackPanel>
      </Grid>
    </DockPanel>
  </Grid>
</sukiUi:SukiWindow>
