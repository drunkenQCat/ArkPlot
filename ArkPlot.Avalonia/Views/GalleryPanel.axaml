<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArkPlot.Avalonia.ViewModels"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="220"
             x:Class="ArkPlot.Avalonia.Views.GalleryPanel"
             x:DataType="vm:GalleryPanelViewModel">

  <UserControl.Resources>
    <!-- 左侧渐隐: 右 100% → 左 0% -->
    <LinearGradientBrush x:Key="LeftFadeMask" StartPoint="100%,0%" EndPoint="0%,0%">
      <GradientStop Color="#FF000000" Offset="0.0"/>
      <GradientStop Color="#00000000" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- 右侧渐隐: 左 0% → 右 100% -->
    <LinearGradientBrush x:Key="RightFadeMask" StartPoint="0%,0%" EndPoint="100%,0%">
      <GradientStop Color="#00000000" Offset="0.0"/>
      <GradientStop Color="#FF000000" Offset="1.0"/>
    </LinearGradientBrush>
  </UserControl.Resources>

  <Border Height="220" BorderBrush="#20FFFFFF"
          BorderThickness="1" CornerRadius="12" ClipToBounds="True"
          Background="#2A2A2A">
    <Panel>
      <!-- 上文 -->
      <StackPanel VerticalAlignment="Top" Margin="16,8,16,0" ZIndex="10">
        <TextBlock Text="{Binding UpperContext1}" FontSize="11"
                   Foreground="#80FFFFFF" TextTrimming="CharacterEllipsis"/>
        <TextBlock Text="{Binding UpperContext2}" FontSize="12"
                   Foreground="#A0FFFFFF" TextTrimming="CharacterEllipsis"/>
      </StackPanel>

      <!-- 下文 -->
      <StackPanel VerticalAlignment="Bottom" Margin="16,0,16,8" ZIndex="10">
        <TextBlock Text="{Binding LowerContext1}" FontSize="12"
                   Foreground="#A0FFFFFF" TextTrimming="CharacterEllipsis"/>
        <TextBlock Text="{Binding LowerContext2}" FontSize="11"
                   Foreground="#80FFFFFF" TextTrimming="CharacterEllipsis"/>
      </StackPanel>

      <!-- 左图 (Prev) - 绝对定位，露出 50px -->
      <Border Width="60" HorizontalAlignment="Left" VerticalAlignment="Center"
              Margin="0,0,-10,0" CornerRadius="6" ClipToBounds="True"
              OpacityMask="{StaticResource LeftFadeMask}"
              IsVisible="{Binding HasPrevBackground}">
        <Panel>
          <Border Background="#383838"/>
          <Image asyncImageLoader:ImageLoader.Source="{Binding PrevBackground}"
                 Stretch="UniformToFill"
                 RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
              <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
            </Image.RenderTransform>
          </Image>
        </Panel>
      </Border>

      <!-- 右图 (Next) - 绝对定位，露出 50px -->
      <Border Width="60" HorizontalAlignment="Right" VerticalAlignment="Center"
              Margin="-10,0,0,0" CornerRadius="6" ClipToBounds="True"
              OpacityMask="{StaticResource RightFadeMask}"
              IsVisible="{Binding HasNextBackground}">
        <Panel>
          <Border Background="#383838"/>
          <Image asyncImageLoader:ImageLoader.Source="{Binding NextBackground}"
                 Stretch="UniformToFill"
                 RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
              <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
            </Image.RenderTransform>
          </Image>
        </Panel>
      </Border>

      <!-- 当前图 (Current) - 居中悬浮卡片 -->
      <Border HorizontalAlignment="Center" VerticalAlignment="Center"
              Width="720" Height="200" Margin="0,-4,0,-4"
              CornerRadius="8" ClipToBounds="True"
              BorderBrush="#60FFFFFF" BorderThickness="1">
        <Panel Background="#3A3A3A">
          <Image asyncImageLoader:ImageLoader.Source="{Binding CurrentBackground}"
                 Stretch="UniformToFill"
                 IsVisible="{Binding HasCurrentBackground}"/>
        </Panel>
      </Border>

      <!-- PicDesc tooltip (附加到当前图) -->
      <Border IsHitTestVisible="False">
        <ToolTip.Tip>
          <TextBlock Text="{Binding CurrentPicDescription}"
                     MaxWidth="300" TextWrapping="Wrap"/>
        </ToolTip.Tip>
      </Border>
    </Panel>
  </Border>
</UserControl>
