<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArkPlot.Avalonia.ViewModels.Test"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="ArkPlot.Avalonia.Views.Test.NetworkFailureTestPanel"
             x:DataType="vm:NetworkFailureTestViewModel">
  <Grid ColumnDefinitions="*" RowDefinitions="Auto,*" Margin="8">
    <!-- 控制区 -->
    <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
      <TextBlock Text="网络中断模拟" FontSize="16" FontWeight="SemiBold"/>
      <TextBlock Text="模拟生成过程中网络连接失败，触发弹窗引导用户跳转到设置页面配置代理。"
                 TextWrapping="Wrap" Opacity="0.6" FontSize="13"/>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="触发网络中断"
                Command="{Binding SimulateNetworkFailureCommand}"
                Classes="Rounded Accent"/>
        <Button Content="清空日志"
                Command="{Binding ClearLogCommand}"
                Classes="Rounded"/>
      </StackPanel>
    </StackPanel>

    <!-- 日志区 -->
    <Border Grid.Row="1" BorderBrush="#30FFFFFF" BorderThickness="1"
            CornerRadius="4" Padding="8">
      <ScrollViewer>
        <TextBlock Text="{Binding Log}"
                   TextWrapping="Wrap"
                   FontFamily="Consolas"
                   FontSize="12"/>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>