<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ArkPlot.Avalonia.ViewModels;assembly=ArkPlot.Avalonia"
        xmlns:b="clr-namespace:Avalonia.Xaml.Behaviors;assembly=Avalonia.Xaml.Behaviors"
        xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="ArkPlot.Avalonia.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="设置" Height="750" Width="600">
    <Window.DataContext>
        <vm:SettingsViewModel />
    </Window.DataContext>
    <i:Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <InvokeCommandAction Command="{Binding LoadSettingsCommand}" />
        </EventTriggerBehavior>
    </i:Interaction.Behaviors>
    <Grid>
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            <!-- Tab 1: 标签替换 -->
            <TabItem Header="标签替换">
                <StackPanel Margin="8">
                    <DataGrid Height="400"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        SelectionMode="Extended"
                        SelectedIndex="{Binding SelectedIndex}"
                        ItemsSource="{Binding DataGrid}"
                        AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="tag名" Binding="{Binding Tag}" Width="130"/>
                            <DataGridTextColumn Header="替换为..." Binding="{Binding NewTag}" Width="130"/>
                            <DataGridTextColumn Header="保留内容格式（正则表达式）" Binding="{Binding Reg}" Width="226"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Width="73" Command="{Binding AddItemCommand}" Margin="0,6,0,0">[    +    ]</Button>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,7,0,0">
                        <Button Width="100" Command="{Binding SaveTagJsonCommand}" Content="保存标签" Margin="0,0,10,0"/>
                        <Button Width="80"
                                Command="{Binding CloseWindowCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                                Content="关闭"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Tab 2: 小说化设置 -->
            <TabItem Header="小说化设置">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8" Spacing="10">
                            <TextBlock Text="系统提示词（System Prompt）" FontWeight="Bold" FontSize="14"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="180">
                                <TextBox Text="{Binding SystemPromptText}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"/>
                            </ScrollViewer>
                            <Button Command="{Binding RestoreDefaultPromptCommand}"
                                    Content="恢复默认提示词"
                                    HorizontalAlignment="Left"
                                    Padding="12,4"/>

                            <Separator Margin="0,5"/>

                            <TextBlock Text="API Key 配置" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="优先使用此处的值；如为空，则读取环境变量" FontSize="11" Foreground="Gray"/>

                            <StackPanel Spacing="4">
                                <TextBlock Text="DeepSeek API Key" FontSize="12"/>
                                <TextBox Text="{Binding DeepSeekApiKeyText}"
                                         PasswordChar="•"
                                         Watermark="留空则使用 DEEPSEEK_API_KEY 环境变量"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="百炼 API Key" FontSize="12"/>
                                <TextBox Text="{Binding BailianApiKeyText}"
                                         PasswordChar="•"
                                         Watermark="留空则使用 DASHSCOPE_API_KEY 环境变量"/>
                            </StackPanel>

                            <Separator Margin="0,5"/>

                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="平台选择" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding ProviderOptions}"
                                              SelectedItem="{Binding SelectedProvider}"
                                              Width="160"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="模型选择" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding ModelOptions}"
                                              SelectedItem="{Binding SelectedModel}"
                                              Width="200"/>
                                </StackPanel>
                            </StackPanel>

                            <Separator Margin="0,5"/>

                            <!-- 多轮对话设置 -->
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <CheckBox IsChecked="{Binding EnableMultiTurn}"
                                                  Content="启用多轮对话模式"
                                                  FontWeight="Bold"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding TokenEstimateText}"
                                                   VerticalAlignment="Center"
                                                   Foreground="Gray"
                                                   FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="Gray"
                                               IsVisible="{Binding EnableMultiTurn}">
                                        <Run Text="多轮模式将长章节拆分为多个小段，逐段生成并保持上下文连贯。适用于章节正文超过 10K 字符的剧情，能有效降低单次调用的 Token 压力，减少场景遗漏和内容压缩。"/>
                                        <LineBreak/>
                                        <Run Text="实验数据（孤星第一章 21KB）：单次调用会丢失开场或中段场景；多轮 + 5KB chunk + 每 2 轮压缩可实现 100% 场景覆盖。"/>
                                        <LineBreak/>
                                        <Run Text="代价是调用次数增多（约 2-4 倍），总 Token 消耗约为单次调用的 1.5-2 倍。"/>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal" Spacing="20"
                                                IsVisible="{Binding EnableMultiTurn}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Chunk Size（字符）" FontSize="12"/>
                                            <TextBox Text="{Binding ChunkSize}"
                                                     Width="100"
                                                     ToolTip.Tip="每轮输入的字符数，越小轮次越多。建议 3000-5000"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="压缩间隔（轮）" FontSize="12"/>
                                            <TextBox Text="{Binding CompressInterval}"
                                                     Width="100"
                                                     ToolTip.Tip="每 N 轮对已有小说内容做一次摘要压缩，清空对话历史以节省上下文空间。0=不压缩。建议 2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,5"/>

                            <!-- 自定义平台管理 -->
                            <Expander Header="自定义平台管理" IsExpanded="False">
                                <StackPanel Spacing="6" Margin="4">
                                    <ListBox ItemsSource="{Binding CustomProviderList}"
                                             SelectedIndex="{Binding SelectedCustomProviderIndex}"
                                             Height="80">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Run Text="{Binding Name}"/>
                                                    <Run Text=" — "/>
                                                    <Run Text="{Binding BaseUrl}" Foreground="Gray"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel Spacing="4">
                                        <TextBox Text="{Binding EditingProviderName}" Watermark="平台名称"/>
                                        <TextBox Text="{Binding EditingProviderUrl}" Watermark="API Base URL（如 https://openrouter.ai/api/v1）"/>
                                        <TextBox Text="{Binding EditingProviderKey}" PasswordChar="•" Watermark="API Key"/>
                                        <TextBox Text="{Binding EditingProviderModelsText}" Watermark="模型列表（逗号分隔，如 gpt-4o,claude-3.5-sonnet）"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Command="{Binding AddCustomProviderCommand}" Content="添加" Padding="12,4"/>
                                        <Button Command="{Binding UpdateCustomProviderCommand}" Content="更新" Padding="12,4"/>
                                        <Button Command="{Binding DeleteCustomProviderCommand}" Content="删除" Padding="12,4" Foreground="#E53935"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Padding="12,8" Background="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <TextBlock Text="{Binding SaveFeedbackText}"
                                       VerticalAlignment="Center"
                                       Foreground="#4CAF50"
                                       FontWeight="Bold"/>
                            <Button Width="100" Command="{Binding SaveNovelizerSettingsCommand}" Content="保存设置"/>
                            <Button Width="80"
                                    Command="{Binding CloseWindowCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                                    Content="关闭"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: 图片描述设置 -->
            <TabItem Header="图片描述设置">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8" Spacing="10">
                            <TextBlock Text="系统提示词（System Prompt）" FontWeight="Bold" FontSize="14"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="150">
                                <TextBox Text="{Binding VisionSystemPrompt}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"/>
                            </ScrollViewer>
                            <Button Command="{Binding RestoreDefaultVisionPromptCommand}"
                                    Content="恢复默认提示词"
                                    HorizontalAlignment="Left"
                                    Padding="12,4"/>

                            <Separator Margin="0,5"/>

                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="平台选择" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding VisionProviderOptions}"
                                              SelectedItem="{Binding VisionSelectedProvider}"
                                              Width="160"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="模型选择" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding VisionModelOptions}"
                                              SelectedItem="{Binding VisionSelectedModel}"
                                              Width="200"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Spacing="4" IsVisible="{Binding IsOllamaProvider}">
                                <TextBlock Text="Ollama 服务地址" FontSize="12"/>
                                <TextBox Text="{Binding VisionOllamaBaseUrl}" Watermark="http://localhost:11434"/>
                            </StackPanel>

                            <Separator Margin="0,5"/>

                            <!-- 自定义平台管理 -->
                            <Expander Header="自定义平台管理" IsExpanded="False">
                                <StackPanel Spacing="6" Margin="4">
                                    <ListBox ItemsSource="{Binding VisionCustomProviderList}"
                                             SelectedIndex="{Binding VisionSelectedCustomProviderIndex}"
                                             Height="80">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Run Text="{Binding Name}"/>
                                                    <Run Text=" — "/>
                                                    <Run Text="{Binding BaseUrl}" Foreground="Gray"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel Spacing="4">
                                        <TextBox Text="{Binding VisionEditingProviderName}" Watermark="平台名称"/>
                                        <TextBox Text="{Binding VisionEditingProviderUrl}" Watermark="API Base URL"/>
                                        <TextBox Text="{Binding VisionEditingProviderKey}" PasswordChar="•" Watermark="API Key"/>
                                        <TextBox Text="{Binding VisionEditingProviderModelsText}" Watermark="模型列表（逗号分隔）"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Command="{Binding AddVisionCustomProviderCommand}" Content="添加" Padding="12,4"/>
                                        <Button Command="{Binding UpdateVisionCustomProviderCommand}" Content="更新" Padding="12,4"/>
                                        <Button Command="{Binding DeleteVisionCustomProviderCommand}" Content="删除" Padding="12,4" Foreground="#E53935"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Padding="12,8" Background="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <TextBlock Text="{Binding VisionSaveFeedbackText}"
                                       VerticalAlignment="Center"
                                       Foreground="#4CAF50"
                                       FontWeight="Bold"/>
                            <Button Width="100" Command="{Binding SaveVisionSettingsCommand}" Content="保存设置"/>
                            <Button Width="80"
                                    Command="{Binding CloseWindowCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                                    Content="关闭"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 4: TTS 配置 -->
            <TabItem Header="TTS配置">
                <Grid ColumnDefinitions="*,220" Margin="16">
                    <!-- 左栏：引擎配置 -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
                        <StackPanel Spacing="16">

                            <!-- EdgeTTS -->
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="EdgeTTS" FontWeight="Bold" FontSize="14"/>
                                    <CheckBox Content="启用（免费，无需配置）"
                                              IsChecked="{Binding TtsEdgeTtsEnabled}"/>
                                    <TextBlock Text="{Binding TtsEdgeTtsSummary}" Foreground="Gray" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- MiniMax -->
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="MiniMax" FontWeight="Bold" FontSize="14"/>
                                    <CheckBox Content="启用"
                                              IsChecked="{Binding TtsMiniMaxEnabled}"/>
                                    <StackPanel Spacing="6" IsVisible="{Binding TtsMiniMaxEnabled}">
                                        <TextBlock Text="API Key" FontSize="12"/>
                                        <TextBox Text="{Binding TtsMiniMaxApiKey}"
                                                 PasswordChar="•"
                                                 Watermark="sk-xxx 或留空使用环境变量"/>
                                        <TextBlock Text="Base URL" FontSize="12"/>
                                        <ComboBox ItemsSource="{Binding MiniMaxBaseUrlOptions}"
                                                  SelectedItem="{Binding TtsMiniMaxBaseUrl}"
                                                  Width="320"
                                                  HorizontalAlignment="Left"/>
                                        <TextBlock Text="模型" FontSize="12"/>
                                        <ComboBox ItemsSource="{Binding MiniMaxModelOptions}"
                                                  SelectedItem="{Binding TtsMiniMaxModel}"
                                                  Width="320"
                                                  HorizontalAlignment="Left"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding TtsMiniMaxVoiceCount, StringFormat='音色 {0} 种'}"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="管理音色..."
                                                    Command="{Binding OpenMiniMaxVoiceManagerCommand}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                                                    Classes="Flat"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 自定义引擎 -->
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="自定义引擎" FontWeight="Bold" FontSize="14"/>

                                    <!-- 引擎列表 -->
                                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="2">
                                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <!-- 表头 -->
                                                <Grid ColumnDefinitions="*,*,80,80" Margin="8,4">
                                                    <TextBlock Text="名称" FontWeight="SemiBold" FontSize="11"/>
                                                    <TextBlock Grid.Column="1" Text="地址" FontWeight="SemiBold" FontSize="11"/>
                                                    <TextBlock Grid.Column="2" Text="音色" FontWeight="SemiBold" FontSize="11"/>
                                                    <TextBlock Grid.Column="3" Text="状态" FontWeight="SemiBold" FontSize="11"/>
                                                </Grid>
                                                <!-- 数据行 -->
                                                <ItemsControl ItemsSource="{Binding TtsCustomEngineList}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,1,0,0" Padding="8,6">
                                                                <Grid ColumnDefinitions="*,*,80,80">
                                                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding BaseUrl}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding Voices.Length, StringFormat='{}{0} 种'}" VerticalAlignment="Center" FontSize="11"/>
                                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                                        <Button Content="编辑" Classes="Flat" FontSize="11" Padding="4,2"
                                                                                Command="{Binding $parent[TabItem].((vm:SettingsViewModel)DataContext).EditTtsCustomEngineCommand}"
                                                                                CommandParameter="{Binding}"/>
                                                                        <Button Content="删除" Classes="Flat" FontSize="11" Padding="4,2"
                                                                                Command="{Binding $parent[TabItem].((vm:SettingsViewModel)DataContext).DeleteTtsCustomEngineCommand}"
                                                                                CommandParameter="{Binding}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>

                                    <Button Content="＋ 添加引擎"
                                            Command="{Binding AddTtsCustomEngineCommand}"
                                            Classes="Flat"
                                            HorizontalAlignment="Right"/>

                                    <!-- 编辑面板（内联展开） -->
                                    <Border BorderBrush="{DynamicResource SystemAccentColor}" BorderThickness="1" CornerRadius="4" Padding="12"
                                            IsVisible="{Binding TtsEditingEngineVisible}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding TtsEditingEngineTitle}" FontWeight="SemiBold" FontSize="13"/>
                                            <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,4,0,0">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" VerticalAlignment="Center" FontSize="12"/>
                                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TtsEditingEngineName}" Watermark="我的本地TTS"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="地址" VerticalAlignment="Center" FontSize="12"/>
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TtsEditingEngineUrl}" Watermark="http://localhost:5144"/>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="API Key" VerticalAlignment="Center" FontSize="12"/>
                                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TtsEditingEngineKey}" PasswordChar="•" Watermark="(可选)"/>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="模型" VerticalAlignment="Center" FontSize="12"/>
                                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TtsEditingEngineModel}" Watermark="(可选)"/>
                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="音色" VerticalAlignment="Center" FontSize="12"/>
                                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding TtsEditingEngineVoiceCount, StringFormat='{}{0} 种'}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Content="管理音色..."
                                                            Command="{Binding OpenEditingEngineVoiceManagerCommand}"
                                                            CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                                                            Classes="Flat"/>
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                                                <Button Content="保存引擎" Command="{Binding SaveEditingEngineCommand}" Classes="Accent" Padding="16,6"/>
                                                <Button Content="取消" Command="{Binding CancelEditingEngineCommand}" Padding="16,6"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 默认音色 -->
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="默认音色" FontWeight="Bold" FontSize="14"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="旁白" VerticalAlignment="Center" FontSize="12"/>
                                        <ComboBox ItemsSource="{Binding TtsAllVoices}"
                                                  SelectedItem="{Binding TtsDefaultNarratorVoice}"
                                                  Width="400">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding Entry.DisplayName}"/>
                                                        <TextBlock Text="·" Foreground="Gray"/>
                                                        <TextBlock Text="{Binding Entry.VoiceId}" Foreground="Gray" FontSize="11"/>
                                                        <TextBlock Text="(" Foreground="Gray" FontSize="11"/>
                                                        <TextBlock Text="{Binding Engine}" Foreground="Gray" FontSize="11"/>
                                                        <TextBlock Text=")" Foreground="Gray" FontSize="11"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 保存按钮 -->
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                                <Button Content="保存所有设置"
                                        Command="{Binding SaveTtsSettingsCommand}"
                                        Padding="20,8"
                                        Classes="Accent"/>
                                <TextBlock Text="{Binding TtsSaveFeedbackText}"
                                           VerticalAlignment="Center"
                                           Foreground="Green"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- 右栏：音色池（实时） -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="12" VerticalAlignment="Top">
                        <StackPanel Spacing="8">
                            <TextBlock Text="音色池（实时）" FontWeight="Bold" FontSize="14"/>
                            <ItemsControl ItemsSource="{Binding TtsPoolBreakdown}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding EngineName}" FontSize="12"/>
                                            <TextBlock Text="●" FontSize="8" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Count, StringFormat='{}{0} 种'}" FontSize="12" Foreground="Gray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,1,0,0" Margin="0,4" Padding="0,4,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding TtsPoolTotalText}" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{Binding TtsPoolGenderText}" Foreground="Gray" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 5: 数据管理 -->
            <TabItem Header="数据管理">
                <StackPanel Margin="16" Spacing="16">
                    <TextBlock Text="数据源同步" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="从 GitHub 和 PRTS Wiki 获取最新数据。强制刷新会无视缓存状态，重新下载并增量更新。"
                               TextWrapping="Wrap" Foreground="Gray"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="语言：" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  Width="120"/>
                    </StackPanel>

                    <Button Content="强制刷新数据"
                            Command="{Binding ForceRefreshDataCommand}"
                            IsEnabled="{Binding !IsDataOperationRunning}"
                            HorizontalAlignment="Left"
                            Padding="20,8"
                            Classes="Accent"/>

                    <Separator Margin="0,8"/>

                    <!-- GitHub 代理设置 -->
                    <TextBlock Text="GitHub 代理镜像" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="通过代理加速 GitHub 数据下载（活动列表、剧情文本）。适用于国内网络环境。"
                               TextWrapping="Wrap" FontSize="11" Foreground="Gray"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox ItemsSource="{Binding ProxyPresetOptions}"
                                  SelectedIndex="{Binding SelectedProxyPresetIndex}"
                                  Width="180"/>
                        <TextBox Text="{Binding GitHubProxyPrefix}"
                                 Width="260"
                                 Watermark="https://gh-proxy.com/ 或留空=直连"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="测试连接"
                                Command="{Binding TestGitHubProxyConnectionCommand}"
                                IsEnabled="{Binding !IsProxyTesting}"
                                Padding="16,6"/>
                        <Button Content="一键测速"
                                Command="{Binding ScanAllProxiesCommand}"
                                IsEnabled="{Binding !IsProxyScanning}"
                                Padding="16,6"
                                Classes="Accent"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ProxyTestStatus}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               FontWeight="Bold"
                               IsVisible="{Binding !IsProxyScanning}"/>
                    <TextBlock Text="{Binding ProxyScanStatus}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               FontWeight="Bold"/>

                    <Separator Margin="0,8"/>

                    <TextBlock Text="危险区域" FontWeight="Bold" FontSize="16" Foreground="#E53935"/>
                    <TextBlock Text="清空数据库中所有缓存数据，包括活动列表、章节内容、PRTS 资源索引等。操作不可撤销。"
                               TextWrapping="Wrap" Foreground="Gray"/>

                    <Button Content="清空全部数据"
                            Command="{Binding ResetAllDataCommand}"
                            IsEnabled="{Binding !IsDataOperationRunning}"
                            HorizontalAlignment="Left"
                            Padding="20,8"
                            Foreground="#E53935"
                            BorderBrush="#E53935"/>

                    <TextBlock Text="{Binding DataManagementStatus}"
                               TextWrapping="Wrap"
                               Foreground="Gray"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
