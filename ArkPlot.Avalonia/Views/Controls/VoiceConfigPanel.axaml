<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArkPlot.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
             x:Class="ArkPlot.Avalonia.Views.Controls.VoiceConfigPanel"
             x:DataType="vm:VoiceConfigPanelViewModel">
  <DockPanel>
    <!-- 工具栏 -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8"
                Margin="0,0,0,8">
      <TextBlock Text="音色配置" FontSize="14" FontWeight="Bold"
                 VerticalAlignment="Center"/>
      <Button Content="🎲 随机分配" FontSize="11" Padding="8,2"
              Command="{Binding RandomizeVoicesCommand}"/>
      <Button Content="💾 保存音色配置" FontSize="11" Padding="8,2"
              Command="{Binding SaveVoiceConfigsCommand}"/>
    </StackPanel>

    <!-- 搜索框 -->
    <TextBox DockPanel.Dock="Top"
             Text="{Binding VoiceConfigSearchText}"
             Watermark="搜索角色名 / 性别 / 音色..."
             Margin="0,0,0,6"/>

    <!-- 统计 -->
    <TextBlock DockPanel.Dock="Top" FontSize="11" Opacity="0.5" Margin="0,0,0,4">
      <Run Text="显示 "/>
      <Run Text="{Binding FilteredVoiceConfigs.Count, Mode=OneWay}"/>
      <Run Text=" / "/>
      <Run Text="{Binding VoiceConfigs.Count, Mode=OneWay}"/>
      <Run Text=" 个角色"/>
    </TextBlock>

    <!-- 配置列表 -->
    <ListBox ItemsSource="{Binding FilteredVoiceConfigs}"
             SelectedItem="{Binding SelectedVoiceConfig}"
             Background="Transparent">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,3">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                       MinWidth="80">
              <Run Text="{Binding CharacterName}" FontWeight="SemiBold"/>
              <LineBreak/>
              <Run Text="{Binding Gender}" FontSize="11" Foreground="{Binding GenderColor}"/>
            </TextBlock>
            <ComboBox Grid.Column="2" Width="280"
                      ItemsSource="{Binding AvailableVoices}"
                      SelectedItem="{Binding SelectedVoice}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             TextWrapping="Wrap"
                             MaxWidth="260"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
