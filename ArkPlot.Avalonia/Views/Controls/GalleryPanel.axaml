<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArkPlot.Avalonia.ViewModels"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="220"
             x:Class="ArkPlot.Avalonia.Views.Controls.GalleryPanel"
             x:DataType="vm:GalleryPanelViewModel">

  <UserControl.Styles>
    <!-- hover 时显示箭头按钮 -->
    <Style Selector="Button.ArrowBtn">
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border#RootContainer:pointerover > Panel > Button.ArrowBtn">
      <Setter Property="Opacity" Value="0.85"/>
    </Style>
  </UserControl.Styles>

  <UserControl.Resources>
    <!-- 左侧渐隐: 右 100% → 左 0% -->
    <LinearGradientBrush x:Key="LeftFadeMask" StartPoint="100%,0%" EndPoint="0%,0%">
      <GradientStop Color="#FF000000" Offset="0.0"/>
      <GradientStop Color="#00000000" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- 右侧渐隐: 左 0% → 右 100% -->
    <LinearGradientBrush x:Key="RightFadeMask" StartPoint="0%,0%" EndPoint="100%,0%">
      <GradientStop Color="#00000000" Offset="0.0"/>
      <GradientStop Color="#FF000000" Offset="1.0"/>
    </LinearGradientBrush>
  </UserControl.Resources>

  <Border x:Name="RootContainer" Height="220" BorderBrush="#20FFFFFF"
          BorderThickness="1" CornerRadius="12" ClipToBounds="True"
          Background="#2A2A2A">
    <Panel>
      <!-- 上文 -->
      <StackPanel VerticalAlignment="Top" Margin="16,8,16,0" ZIndex="10"
                  IsHitTestVisible="False">
        <TextBlock Text="{Binding UpperContext1}" FontSize="11"
                   Foreground="#80FFFFFF" TextTrimming="CharacterEllipsis"/>
        <TextBlock Text="{Binding UpperContext2}" FontSize="12"
                   Foreground="#A0FFFFFF" TextTrimming="CharacterEllipsis"/>
      </StackPanel>

      <!-- 下文 -->
      <StackPanel VerticalAlignment="Bottom" Margin="16,0,16,8" ZIndex="10"
                  IsHitTestVisible="False">
        <TextBlock Text="{Binding LowerContext1}" FontSize="12"
                   Foreground="#A0FFFFFF" TextTrimming="CharacterEllipsis"/>
        <TextBlock Text="{Binding LowerContext2}" FontSize="11"
                   Foreground="#80FFFFFF" TextTrimming="CharacterEllipsis"/>
      </StackPanel>

      <!-- 左图 (Prev) - 绝对定位，露出 50px -->
      <Border Width="60" HorizontalAlignment="Left" VerticalAlignment="Center"
              Margin="0,0,-10,0" CornerRadius="6" ClipToBounds="True"
              OpacityMask="{StaticResource LeftFadeMask}"
              IsVisible="{Binding HasPrevBackground}"
              IsHitTestVisible="False">
        <Panel>
          <Border Background="#383838"/>
          <Image asyncImageLoader:ImageLoader.Source="{Binding PrevBackground}"
                 Stretch="UniformToFill"
                 RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
              <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
            </Image.RenderTransform>
          </Image>
        </Panel>
      </Border>

      <!-- 右图 (Next) - 绝对定位，露出 50px -->
      <Border Width="60" HorizontalAlignment="Right" VerticalAlignment="Center"
              Margin="-10,0,0,0" CornerRadius="6" ClipToBounds="True"
              OpacityMask="{StaticResource RightFadeMask}"
              IsVisible="{Binding HasNextBackground}"
              IsHitTestVisible="False">
        <Panel>
          <Border Background="#383838"/>
          <Image asyncImageLoader:ImageLoader.Source="{Binding NextBackground}"
                 Stretch="UniformToFill"
                 RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
              <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
            </Image.RenderTransform>
          </Image>
        </Panel>
      </Border>

      <!-- 当前图 (Current) - 居中悬浮卡片，点击放大 -->
      <Button HorizontalAlignment="Center" VerticalAlignment="Center"
              Width="720" Height="200" Margin="0,-4,0,-4"
              IsVisible="{Binding HasCurrentBackground}"
              ToolTip.Tip="点击放大查看">
        <Button.Template>
          <ControlTemplate>
            <Border CornerRadius="8" ClipToBounds="True"
                    BorderBrush="#60FFFFFF" BorderThickness="1">
              <Panel Background="#3A3A3A">
                <Image asyncImageLoader:ImageLoader.Source="{Binding $parent[Button].((vm:GalleryPanelViewModel)DataContext).CurrentBackground}"
                       Stretch="UniformToFill"/>
              </Panel>
            </Border>
          </ControlTemplate>
        </Button.Template>
        <Button.Flyout>
          <Flyout Placement="Bottom">
            <Flyout.FlyoutPresenterTheme>
              <ControlTheme TargetType="FlyoutPresenter">
                <Setter Property="Background" Value="#1A1A1A"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="BorderBrush" Value="#60FFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="4"/>
                <Setter Property="MaxWidth" Value="900"/>
                <Setter Property="MaxHeight" Value="600"/>
              </ControlTheme>
            </Flyout.FlyoutPresenterTheme>
            <StackPanel Spacing="8">
              <Image asyncImageLoader:ImageLoader.Source="{Binding $parent[UserControl].((vm:GalleryPanelViewModel)DataContext).CurrentBackground}"
                     Stretch="Uniform"
                     MaxWidth="880" MaxHeight="500"/>
              <TextBlock Text="{Binding $parent[UserControl].((vm:GalleryPanelViewModel)DataContext).CurrentPicDescription}"
                         TextWrapping="Wrap" MaxWidth="880"
                         FontSize="12" Foreground="#C0FFFFFF"
                         IsVisible="{Binding $parent[UserControl].((vm:GalleryPanelViewModel)DataContext).CurrentPicDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>
          </Flyout>
        </Button.Flyout>
      </Button>

      <!-- PicDesc tooltip (附加到当前图，hover 时显示简短描述) -->
      <Border IsHitTestVisible="False" ZIndex="5">
        <ToolTip.Tip>
          <TextBlock Text="{Binding CurrentPicDescription}"
                     MaxWidth="300" TextWrapping="Wrap"/>
        </ToolTip.Tip>
      </Border>

      <!-- 左箭头 (hover 显示) -->
      <Button Classes="ArrowBtn" ZIndex="20"
              HorizontalAlignment="Left" VerticalAlignment="Center"
              Margin="8,0,0,0"
              Command="{Binding JumpToPrevCommand}"
              IsVisible="{Binding CanJumpPrev}"
              ToolTip.Tip="跳转到上一场景">
        <Button.Template>
          <ControlTemplate>
            <Border Background="#80000000" CornerRadius="16"
                    Width="32" Height="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="◀" FontSize="14" Foreground="White"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Button.Template>
      </Button>

      <!-- 右箭头 (hover 显示) -->
      <Button Classes="ArrowBtn" ZIndex="20"
              HorizontalAlignment="Right" VerticalAlignment="Center"
              Margin="0,0,8,0"
              Command="{Binding JumpToNextCommand}"
              IsVisible="{Binding CanJumpNext}"
              ToolTip.Tip="跳转到下一场景">
        <Button.Template>
          <ControlTemplate>
            <Border Background="#80000000" CornerRadius="16"
                    Width="32" Height="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="▶" FontSize="14" Foreground="White"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Button.Template>
      </Button>
    </Panel>
  </Border>
</UserControl>
